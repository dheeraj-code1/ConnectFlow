{
  "manifest_version": 3,
  "name": "Page Button Extension",
  "version": "1.0.0",
  "description": "Injects a Connect All button on LinkedIn company people pages.",
  "permissions": ["webNavigation"],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}

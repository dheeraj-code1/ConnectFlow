{
  "manifest_version": 3,
  "name": "ConnectFlow",
  "version": "1.0.0",
  "description": "Bulk connect on LinkedIn company People pages — one click, many connections.",
  "permissions": ["webNavigation", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
